# DockerMap draft deployment environment
#
# Copy this to /etc/dockermap/dockermap.env on the review host and fill in real values.
# Keep this file readable only by the service user/root because it contains the API token.

# Node browser-facing API. The API intentionally binds to 127.0.0.1 in code.
NODE_ENV=production
PORT=4000
DOCKERMAP_DAEMON_URL=http://127.0.0.1:4100
DOCKERMAP_API_TOKEN=replace-with-a-long-random-value
DOCKERMAP_ALLOWED_ORIGINS=https://dockermap.example.com
DOCKERMAP_ALLOW_MOCK=false
DOCKERMAP_EXPOSE_ERROR_DETAILS=false
DOCKERMAP_SSE_INTERVAL_MS=2000

# Rust daemon. Keep this private for review deployments.
DOCKERMAP_DAEMON_HOST=127.0.0.1
DOCKERMAP_DAEMON_PORT=4100
DOCKERMAP_PROJECT_ROOT=/opt/dockermap
# Optional: limit Docker collection to resources with one Docker label expression.
# Example: DOCKERMAP_DOCKER_LABEL_FILTER=com.dockermap.fixture=abc123
DOCKERMAP_DOCKER_LABEL_FILTER=

# Only set this to true if the daemon must talk or listen outside loopback.
DOCKERMAP_ALLOW_REMOTE_DAEMON=false
